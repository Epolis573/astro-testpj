---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import GlobalStaggeredMenu from "../components/GlobalStaggeredMenu";
import { getCloudinaryFolderUrls } from "../lib/cloudinary";

interface Props {
  title?: string;
}

const { title = "Astro Basics" } = Astro.props;
const loadingAnimations = await getCloudinaryFolderUrls({
  folderName: "loading-animation",
  maxResults: 12,
  transformation: "f_auto,q_auto,w_420",
});
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body>
		<slot />
		<GlobalStaggeredMenu
			client:load
			transition:persist
			loadingAnimations={loadingAnimations}
		/>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		padding: 0;
		overflow: hidden;
	}
</style>
